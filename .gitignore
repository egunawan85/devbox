# Operator-local deploy config (contains your key paths / choices, not secrets,
# but machine-specific) — never commit. devbox.conf = default 'linux' profile;
# targets/<profile>.conf = other profiles (e.g. windows).
deploy/devbox.conf
deploy/targets/*.conf

# Operator's plaintext secret store (one <project>.env per project, pushed into the
# box's vault by `devbox vault load`). PLAINTEXT SECRETS — never commit.
/secrets/

# Operator-local session-secrets manifest (maps vault projects -> app .env paths).
# Not secret values, but machine/app-specific — see deploy/secrets.map.example.
deploy/secrets.map

# Local Claude session overrides.
.claude/settings.local.json

# In-tree scratch space for agents (verification / throwaway files).
# Scratch goes in ./tmp/, never /tmp or /var/tmp — see claude-config/CLAUDE.md.
/tmp/

# Misc
*.log
.DS_Store
