# Operator-local deploy config (contains your key paths / choices, not secrets,
# but machine-specific) — never commit.
deploy/devbox.conf

# Operator's plaintext secret store (one <project>.env per project, pushed into the
# box's vault by `devbox vault load`). PLAINTEXT SECRETS — never commit.
/secrets/

# Local Claude session overrides.
.claude/settings.local.json

# Misc
*.log
.DS_Store
