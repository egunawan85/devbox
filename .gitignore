# Operator-local deploy config (your key paths / choices — machine-specific, not secrets).
# Per-profile: deploy/targets/<profile>.conf (the *.conf.example templates ARE committed).
# A legacy deploy/devbox.conf (the pre-profiles 'default' conf) is still honored if present.
deploy/devbox.conf
deploy/targets/*.conf

# Defense-in-depth. Sensitive per-deployment state — plaintext <project>.env files, the
# session-secrets manifest, and vault unseal keys — now lives OUTSIDE the repo at
# ~/.config/devbox/<profile>/ and is never in the tree. These rules remain as a backstop in
# case anything sensitive is ever placed here by hand. PLAINTEXT SECRETS — never commit.
/secrets/
deploy/secrets.map
deploy/secrets.*.map

# Local Claude state — session overrides, task worktrees. The shareable payload
# lives in claude-config/, never here.
.claude/

# In-tree scratch space for agents (verification / throwaway files).
# Scratch goes in ./tmp/, never /tmp or /var/tmp — see claude-config/CLAUDE.md.
/tmp/

# Ephemeral planning docs — throwaway slice/task breakdowns for in-flight work.
# Never referenced from committed code/commits/PRs (see "Write for the long term").
docs/plan/

# Misc
*.log
.DS_Store
