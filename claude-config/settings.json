{
    "attribution":
    {
        "commit": ""
    },
    "permissions":
    {
        "allow":
        [
            "Bash",
            "PowerShell",
            "Read"
        ],
        "ask":
        [
            "Bash(cd:*)",
            "Bash(ssh:*)",
            "Bash(git push:*)",
            "Bash(git pull:*)",
            "Bash(git fetch:*)",
            "Bash(git clone:*)",
            "Bash(git merge:*)",
            "Bash(git commit:*)",
            "Bash(git rebase:*)",
            "Bash(git reset:*)",
            "Bash(git revert:*)",
            "Bash(git checkout:*)",
            "Bash(git switch:*)",
            "Bash(git restore:*)",
            "Bash(git add:*)",
            "Bash(git rm:*)",
            "Bash(git mv:*)",
            "Bash(git apply:*)",
            "Bash(git am:*)",
            "Bash(git cherry-pick:*)",
            "Bash(git clean:*)",
            "Bash(git stash:*)",
            "PowerShell(cd:*)",
            "PowerShell(Set-Location:*)",
            "PowerShell(ssh:*)",
            "PowerShell(git push:*)",
            "PowerShell(git pull:*)",
            "PowerShell(git fetch:*)",
            "PowerShell(git clone:*)",
            "PowerShell(git merge:*)",
            "PowerShell(git commit:*)",
            "PowerShell(git rebase:*)",
            "PowerShell(git reset:*)",
            "PowerShell(git revert:*)",
            "PowerShell(git checkout:*)",
            "PowerShell(git switch:*)",
            "PowerShell(git restore:*)",
            "PowerShell(git add:*)",
            "PowerShell(git rm:*)",
            "PowerShell(git mv:*)",
            "PowerShell(git apply:*)",
            "PowerShell(git am:*)",
            "PowerShell(git cherry-pick:*)",
            "PowerShell(git clean:*)",
            "PowerShell(git stash:*)"
        ]
    },
    "hooks":
    {
        "PreToolUse":
        [
            {
                "matcher": "Bash|PowerShell",
                "hooks":
                [
                    {
                        "type": "command",
                        "command": "node \"$HOME/.claude/hooks/git-write-guard.js\"",
                        "shell": "bash",
                        "timeout": 15,
                        "statusMessage": "Checking git write-guard"
                    }
                ]
            }
        ]
    },
    "autoUpdatesChannel": "latest",
    "theme": "dark",
    "agentPushNotifEnabled": true,
    "model": "claude-fable-5[1m]"
}