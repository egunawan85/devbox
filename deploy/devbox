#!/usr/bin/env bash
# devbox — provision / configure / destroy a cloud devbox (Linux/DO or Windows/Azure).
#
# Profiles select the target: -p/--profile <name> (or DEVBOX_PROFILE). Default 'linux'
# reads deploy/devbox.conf; other profiles read deploy/targets/<profile>.conf.
#
# Usage:
#   devbox [-p PROFILE] up                ALL-IN-ONE: provision + configure + vault + load + toolchain
#   devbox [-p PROFILE] configure [--host H]   (re)install config on an existing box
#   devbox [-p PROFILE] ssh               connect (agent-forwarded) to the box
#   devbox [-p PROFILE] status            show the box
#   devbox [-p PROFILE] render            print the rendered first-boot config (no API calls)
#   devbox [-p PROFILE] doctor            check operator prereqs (machine identity, provider CLI/auth)
#   devbox [-p PROFILE] toolchain         (re)install the project build toolchain (windows: ~20-30 min; `up` already runs it once)
#   devbox [-p PROFILE] vault up          bring the vault to ready (start + init/unseal)
#   devbox [-p PROFILE] vault init        init + unseal a fresh box (saves keys to laptop)
#   devbox [-p PROFILE] vault unseal      re-unseal an existing box from your saved key
#   devbox [-p PROFILE] vault load <proj> push ~/devbox-secrets/<proj>.env into the vault
#   devbox [-p PROFILE] vault refresh [proj]  load <proj> (or all) + re-materialize live
#   devbox [-p PROFILE] vault status      initialized / sealed?
#   devbox [-p PROFILE] down [--yes]      destroy the box + firewall
#
# Config: deploy/devbox.conf (default 'linux' profile) or deploy/targets/<profile>.conf.
# DO token via doctl / DIGITALOCEAN_ACCESS_TOKEN; Azure via az login (subscription
# pinned per profile). Copy devbox.conf.example to devbox.conf to get started.
set -euo pipefail

# Resolve symlinks so a `devbox` symlink on PATH still finds its libs / configs next to
# the *real* script (BSD/macOS readlink has no -f, so walk the link chain by hand).
SELF=$0
while [ -L "$SELF" ]; do
  _dir=$(CDPATH= cd -- "$(dirname -- "$SELF")" && pwd)
  SELF=$(readlink -- "$SELF")
  case $SELF in /*) ;; *) SELF=$_dir/$SELF ;; esac
done
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$SELF")" && pwd)

# The generic layer (helpers, profile/conf resolution, orchestration, vault). Provider-
# and OS-specific code lives under providers/ and os/, sourced by main() per profile.
. "$SCRIPT_DIR/lib/common.sh"

main "$@"
