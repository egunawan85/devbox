# devbox 'rg' profile (example) — Azure / Windows Server 2022 build-test box.
# A profile is a DEPLOYMENT name, not an OS (the OS is the OS= field below) — name it for the
# box, not the platform. Copy to deploy/targets/<name>.conf (gitignored) and edit; select with:
#   devbox -p <name> up | configure | ssh | status | down | vault ...
#
# Azure auth is interactive: run `az login` once on this machine (browser, or
# `az login --use-device-code`). The subscription is pinned per-profile below
# (SUBSCRIPTION_ID); the CLI runs `az account set` so it never depends on whatever
# subscription happens to be globally active.

PROVIDER=azure
OS=windows

# --- Azure target ---
# SUBSCRIPTION_ID: az account list --query "[?name=='<your sub>'].id" -o tsv
SUBSCRIPTION_ID=
RESOURCE_GROUP=devbox-rg
REGION=southeastasia
# 4 vCPU / 16 GB — room for VS Build Tools + SQL Express + a build. AMD Dads_v7; chosen
# because the Intel Dsv5 family had a 0-core quota on this subscription/region (check yours
# with `az vm list-usage -l <region>`; request an increase or pick a family that has quota).
SIZE=Standard_D4ads_v7
IMAGE=MicrosoftWindowsServer:WindowsServer:2022-datacenter-azure-edition:latest

# Generic name knobs shared with the common core: the VM name, the NSG (firewall) name,
# and an Azure tag. DROPLET_NAME is the historical key the core uses for "the box".
DROPLET_NAME=devbox-win
FIREWALL_NAME=devbox-win-nsg
TAG=devbox

# --- Access (key-only SSH on a non-default port; no RDP) ---
DEVBOX_USER=eddyg
SSH_PORT=2222
# Public key(s) authorized to log in. Space/newline list. (Windows OpenSSH can't forward your
# agent; project-repo git on the box uses `gh` over HTTPS — see the README's Windows section.)
SSH_PUBKEY_FILES="$HOME/.ssh/id_ed25519.pub"

# --- Config source (cloned on the box during `configure`, via your forwarded key) ---
REPO_URL=git@github.com:egunawan85/devbox.git
REPO_BRANCH=main
# Checkout path on the Windows box. Forward slashes are fine for OpenSSH + PowerShell.
REPO_DIR=C:/Users/eddyg/devbox

# --- Secrets (devbox vault, ported to Windows — Phase 2b Layer C) ---
# Sensitive state (your <project>.env files, the session-secrets manifest with C:\... dest
# paths, and this box's vault unseal key) lives OUTSIDE the repo at ~/.config/devbox/<profile>/.
# Override SECRETS_DIR / SECRETS_MAP / VAULT_KEYS_FILE here only for a non-default location.
VAULT_MOUNT=secret
