# devbox deploy config for the 'default' profile (DigitalOcean / Linux).
#   cp deploy/targets/default.conf.example deploy/targets/default.conf   # then edit
#
# A profile names a DEPLOYMENT (its config + provider + OS), run via `devbox -p <profile>`;
# 'default' is what bare `devbox` uses. Add more boxes as deploy/targets/<name>.conf.
# The DigitalOcean API token is NOT stored here — provide it via doctl
# (`doctl auth init`) or the DIGITALOCEAN_ACCESS_TOKEN environment variable.

# --- Droplet ---
DROPLET_NAME=devbox
REGION=sgp1
SIZE=s-2vcpu-4gb
IMAGE=ubuntu-24-04-x64
TAG=devbox
FIREWALL_NAME=devbox-fw

# --- Access ---
DEVBOX_USER=eddyg
SSH_PORT=2222
# Public keys allowed to log in (laptop + desktop). Space- or newline-separated
# paths. These authorize login AND are the keys you forward for outbound git.
SSH_PUBKEY_FILES="$HOME/.ssh/id_ed25519.pub"

# --- Config source (cloned on the box during `configure`, via your forwarded key) ---
REPO_URL=git@github.com:egunawan85/devbox.git
REPO_BRANCH=main
# Where the repo is checked out on the box (install.sh runs from here).
REPO_DIR=/home/eddyg/devbox

# --- Secrets (devbox vault) ---
# Sensitive per-deployment state — your <project>.env files, the session-secrets manifest, and
# this box's vault unseal key — lives OUTSIDE the repo at ~/.config/devbox/<profile>/, never in
# the tree. You don't normally set paths here; override SECRETS_DIR / SECRETS_MAP /
# VAULT_KEYS_FILE only to use a non-default location.
# KV mount inside the box's OpenBao; a project lands at <mount>/<project>.
VAULT_MOUNT=secret
# Optional auto-seal TTL: if set, the vault re-seals this long after each unseal (a hard
# timer, reset on every unseal). Empty = stay unsealed until reboot/manual seal. A systemd
# timer on the box does it, using a seal-only token (can lock, can't read). Re-locks a
# forgotten-unsealed vault; does NOT wipe already-materialized session .env files.
#AUTOSEAL_TTL=5min        # e.g. 300, 5min, 1h  (empty/unset = disabled)

# --- Provisioning resilience (bad-VM detector) ---
# DigitalOcean occasionally hands you a droplet that boots "active" but is wedged at the
# hypervisor (no SSH, no ping, console won't attach) — not a config problem. `up` detects
# this fast via a scoped ICMP liveness probe (temporarily allows ICMP from YOUR public IP
# only, auto-removed) and recreates on a fresh host instead of a ~20-min silent timeout.
# Defaults shown; uncomment to override.
#LIVENESS_PROBE=on        # on|off — set off to disable the ICMP probe (falls back to SSH-only wait)
#LIVENESS_TIMEOUT=240     # secs with no ping AND no SSH before declaring a bad VM
#READINESS_TIMEOUT=1200   # secs budget for cloud-init to finish the install
#PROVISION_ATTEMPTS=2     # total create attempts; >1 auto-recreates on a bad VM
#PROBE_INTERVAL=10        # secs between probes
#DEATH_STREAK=6           # consecutive missed pings (after being alive) => died mid-install
